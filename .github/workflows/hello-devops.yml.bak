name: "Production-Ping"
on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: read

jobs:
  security-scan:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0 # Trufflehog needs the full history to find deleted secrets

      - name: "Secret Scanning"
        # We are using a community action here
        uses: trufflesecurity/trufflehog@main
        with:
          base: ${{ github.event.repository.default_branch }}
          head: HEAD



  ping-test:
    runs-on: "ubuntu-latest"

    steps:
      - name: "Checkout Code"
        uses: actions/checkout@v4

      - name: "Check Version"
        run: node -v

      - name: "Final Message"
        run: echo "Devops Pipline is LIVE!"

      - name: "Debug - List all files"
        run: ls -R

      - name: "Verify config Exists"
        run: ls configs/app-config.yml

      - name: "Security Audit"
        run: |
          echo "Triggered by ${{ github.actor }}"
          echo "Event Type: ${{ github.event_name }}"
          echo "Branch/Tag: ${{ github.ref }}"

  database-migration:
    runs-on: ubuntu-latest

    steps:
      - name: "Run Migration"
        env:
          DB_PASS: ${{ secrets.DB_PASSWORD}}

        run: |
          echo "Connecting to DB with password..."
          echo "The password is: $DB_PASS"

  optimized-build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: "Cache Dependencies"
        id: cache-npm
        uses: actions/cache@v4
        with:
          path: ~/.cache/pip
          key: ${{ runner.os }}-pip-${{ hashFiles('requirements.txt') }}
            # The 'key' is a unique fingerprint. If requirements.txt changes, the key changes.


      - name: "Install Dependencies (Simulated)"
        run: |
          mkdir -p ~/.cache/pip
          echo "Downloading 500MB of dependencies..."
          sleep 5 # Simulate a slow download
          touch ~/.cache/pip/installed_packages.txt


  build:
    runs-on: ubuntu-latest
    steps:
      - name: "Create Build Artifact"
        run: echo "This is the compiled binary" > build-app.txt
      - name: "Upload Artifact"
        uses: actions/upload-artifact@v4
        with:
          name: app-binary # the name of the package
          path: build-app.txt # the file to save

  test:
    runs-on: ubuntu-latest
    needs: build # This is the magic Link
    steps:
      - name: "Download Artifact"
        uses: actions/download-artifact@v4
        with:
          name: app-binary # must match the upload name!
      - name: "Verify Artifact"
        run: cat build-app.txt

  call-reusable-build:
    needs: [test]
    uses: ./.github/workflows/reusable-docker.yml # local path to your template
    # Note: No 'steps' allowed here!

  deploy-production:
    runs-on: ubuntu-latest
    needs: [test]
    environment: production
    if: github.ref == 'refs/heads/main' # the safety switch
    steps:
      #- name: "Deploying to Production"
      #  run: echo "Deploying to the live cluster..."
      - name: "Deploying"
        run: echo "Manual approval received"
  
  container-build:
    runs-on: ubuntu-latest
    needs: [test]
    permissions:
      contents: read
      packages: write # Mandatory to push to GHCR
  
    steps:
      - uses: actions/checkout@v4
      
      - name: "Log in to GHCR"
        run: echo "${{ secrets.GITHUB_TOKEN }}" | docker login ghcr.io -u ${{ github.actor }} --password-stdin

      - name: "Build and Push Image"
        run: |
          # the name must be lowercase for GHCR
          IMAGE_NAME=ghcr.io/${{ github.repository_owner }}/my-devops-app:${{ github.sha }}

          docker build -t $IMAGE_NAME .
          docker push $IMAGE_NAME

  on-failure-alert:
    runs-on: ubuntu-latest
    needs: [build, test, container-build]
    if: failure() # this is the secret sauce
    steps:
      - name: "Send Emergency Notification"
        run: |
          echo "PIPLINE FAILURE DETECTED"
          echo "One of the critical stages failed."
          echo "Investigating logs for ${{ github.sha }}..."




















